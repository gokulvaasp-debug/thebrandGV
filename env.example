import React, { useState } from "react";
import { motion, AnimatePresence } from "motion/react";
import { BookOpen, Clock, Calendar, ArrowRight, CornerDownRight, ChevronDown } from "lucide-react";
import { Thought } from "../types";

export default function Thoughts() {
  const [expandedThoughtId, setExpandedThoughtId] = useState<string | null>(null);
  const [visibleCount, setVisibleCount] = useState<number>(3);

  const thoughts: Thought[] = [
    {
      id: "nike-swoosh-narrative",
      title: "Why the Nike Swoosh hasn't changed, but their copy did",
      category: "Brand Voice",
      readTime: "3 min read",
      date: "June 2026",
      snippet: "Nike's brand is worth billions not because of rubber sole formulas, but because of their deliberate transition from physical specifications to an emotional state of mind.",
      content: "In the 1970s, athletic running companies marketed heavy technical metrics—sole weights in ounces, lateral heel cup widths, and polyurethane shock-absorption ratings. Nike's genius was realizing that 90% of buyers aren't professional Olympic sprinters; they are regular humans struggling to conquer self-doubt, get out of bed, and run under cold morning rain. By replacing physics graphs with the primal call of 'Just Do It', Nike stopped selling physical footwear and started selling human resilience. A product is simply a modular tool, but a premium brand is a permanent psychological companion in your user's personal growth journey.",
    },
    {
      id: "apple-of-coffee",
      title: "The Apple of Coffee: How Blue Bottle engineered premium obsession",
      category: "Strategy",
      readTime: "4 min read",
      date: "May 2026",
      snippet: "How a humble garage slow-drip experiment charged double coffee-giant prices by engineering sensory rituals and minimalist design friction.",
      content: "Blue Bottle didn't conquer traditional coffee giants with retail expansion velocity, but through deliberate sensory slowdown. Standard coffee franchises prioritized high-automation, drive-thru speed, and chemical syrups. Blue Bottle engineered friction—restarting manual, brass-detailed slow-pour drippers where watching the steam bubble became an intentional, aesthetic mindfulness session. Combined with clean, Cupertino-style natural wood tables and zero clutter, they transformed a hurried caffeine shot into a high-end ritual. They proved that consumers don't hate friction; they will happily pay double for friction that makes them feel sophisticated.",
    },
    {
      id: "ai-vs-nostalgia",
      title: "AI can write copy, but it can't feel nostalgia: the future of strategic direction",
      category: "Future of design",
      readTime: "3 min read",
      date: "April 2026",
      snippet: "Why outstanding creative direction in a post-AI world depends on irrational, lived human memories that algorithms cannot mathematically compute.",
      content: "Algorithms can instantly analyze millions of high-performing ad patterns, optimizing headline lengths and predicting syntax performance. But what AI cannot experience is the specific, irrational warmth of a 1999 summer afternoon—the dust catching light in a local record store, the solid click of an analog tape recorder, or the crinkle of a physical magazine page. Luxury marketing doesn't thrive on perfect logic; it runs on irrational memories and cultural quirks. The future Brand Consultant uses AI to generate massive volume options, but relies strictly on quiet human empathy to edit and anchor the final nostalgic emotional bridge.",
    },
    {
      id: "liquid-death-tap",
      title: "Liquid Death: Selling heavy metal hydration",
      category: "Branding",
      readTime: "3 min read",
      date: "March 2026",
      snippet: "How a brand turned regular tap water into a cult symbol by treating healthy hydration as an extreme sport.",
      content: "Liquid Death disproved the traditional safe, medicalized, and serene aesthetic of bottled water. By packaging mineral water in tallboy aluminum craft beer cans with horror-themed gothic typography and the slogan 'Murder Your Thirst', they successfully targeted consumers who wanted to healthy-hydrate at music venues, bars, and skate parks without looking like they were carrying a soft medical supplement. They proved that branding isn't about explaining product chemistry, but about helping consumers navigate the social psychology of peer groups.",
    },
    {
      id: "patagonia-anti-growth",
      title: "Patagonia's Anti-Growth Paradox: The power of honest constraints",
      category: "Sustainability",
      readTime: "4 min read",
      date: "February 2026",
      snippet: "Why running full-page advertisements asking customers NOT to buy your bestselling jacket actually drives record-breaking organic customer loyalty.",
      content: "When Patagonia ran their famous Black Friday advertisement reading 'Don't Buy This Jacket', traditional retail executives predicted a marketing disaster. Instead, it triggered record revenues. By highlighting the environmental cost of manufacturing and offering free lifelong repairs for older garments, Patagonia built radical authenticity. Modern consumers have developed extreme immunity to cheap promotional marketing. When a brand actively sacrifices immediate short-term transactions to protect its long-term philosophical core, it earns an elite level of consumer trust that money cannot buy.",
    },
    {
      id: "lego-creative-system",
      title: "The LEGO modular system: How infinite creative parameters defeat digital fatigue",
      category: "Human Experience",
      readTime: "3 min read",
      date: "January 2026",
      snippet: "Why plastic bricks with physical design friction continue to scale in a world increasingly dominated by frictionless micro-stimuli.",
      content: "LEGO is brilliant because of its strict adherence to absolute compatibility. A brick manufactured in 1980 fits seamlessly with a brick molded yesterday. In a digital landscape where software applications deprecate, reform, and change overnight and screen-time fatigue is at an all-time high, physical tactile systems offer grounding. Infinite options in digital space often lead to cognitive paralysis; simple, high-friction, bounded physical geometries stimulate creative play and physical spatial mastery. True brand longevity comes from defining a core modular rule that remains invariant across generations.",
    }
  ];

  // Map month names to indices for deterministic latest-first sorting
  const parseDate = (dateStr: string) => {
    const [month, year] = dateStr.split(" ");
    const months: Record<string, number> = {
      January: 0, February: 1, March: 2, April: 3, May: 4, June: 5,
      July: 6, August: 7, September: 8, October: 9, November: 10, December: 11
    };
    return new Date(parseInt(year), months[month] ?? 0).getTime();
  };

  // Ensure latest is always first
  const sortedThoughts = [...thoughts].sort((a, b) => parseDate(b.date) - parseDate(a.date));

  const toggleExpand = (id: string, e: React.MouseEvent) => {
    // Avoid expanding when clicking other elements inside if needed
    setExpandedThoughtId(expandedThoughtId === id ? null : id);
  };

  const handleViewMore = () => {
    setVisibleCount((prev) => Math.min(prev + 3, sortedThoughts.length));
  };

  return (
    <section id="thoughts" className="py-24 bg-slate-50 text-[#050719] relative">
      <div className="max-w-7xl mx-auto px-6 md:px-12">
        
        {/* Header */}
        <div className="max-w-2xl text-left space-y-4 mb-20">
          <div className="flex items-center space-x-2">
            <span className="w-2 h-2 rounded-full bg-[#7B61FF]" />
            <span className="font-display text-[10px] tracking-[0.25em] text-[#7B61FF] uppercase font-bold">Decoding Logs</span>
          </div>
          <h2 className="font-display text-4xl md:text-5xl font-black tracking-tighter text-[#050719] leading-tight">
            Thoughts & Decoded Logics.
          </h2>
          <p className="font-sans text-sm md:text-base text-slate-500 leading-relaxed">
            Direct essays on marketing culture, brand design psychology, and strategic observations from the desk of BrandGV.
          </p>
        </div>

        {/* Thoughts List */}
        <div className="space-y-6 max-w-4xl mx-auto">
          {sortedThoughts.slice(0, visibleCount).map((tg, idx) => {
            const isExpanded = expandedThoughtId === tg.id;
            return (
              <motion.div
                key={tg.id}
                initial={{ opacity: 0, y: 15 }}
                whileInView={{ opacity: 1, y: 0 }}
                viewport={{ once: true, margin: "-100px" }}
                transition={{ duration: 0.5, delay: Math.min(idx, 2) * 0.1 }}
                className={`bg-white rounded-3xl border transition-all duration-300 p-6 md:p-8 cursor-pointer relative overflow-hidden ${
                  isExpanded ? "border-[#7B61FF] shadow-lg bg-white" : "border-gray-150 hover:border-gray-300 shadow-sm"
                }`}
                onClick={(e) => toggleExpand(tg.id, e)}
              >
                {/* Meta Row: Cat, date, read time */}
                <div className="flex flex-wrap items-center gap-3 text-xs font-mono text-gray-400 mb-4">
                  <span className="text-[#7B61FF] uppercase tracking-wider font-extrabold">{tg.category}</span>
                  <span>•</span>
                  <span className="flex items-center space-x-1">
                    <Calendar className="w-3.5 h-3.5" />
                    <span>{tg.date}</span>
                  </span>
                  <span>•</span>
                  <span className="flex items-center space-x-1">
                    <Clock className="w-3.5 h-3.5" />
                    <span>{tg.readTime}</span>
                  </span>
                </div>

                {/* Title */}
                <h3 className="font-serif text-2xl font-bold text-[#050719] hover:text-[#7B61FF] transition-colors leading-tight text-left">
                  {tg.title}
                </h3>

                {/* Snippet / Short view */}
                <p className="font-sans text-sm text-slate-500 leading-relaxed text-left mt-3 font-light">
                  {tg.snippet}
                </p>

                {/* Expand Indicator button */}
                <div className="flex items-center space-x-2 text-[#7B61FF] text-xs font-mono font-bold uppercase mt-6 pt-4 border-t border-gray-100">
                  <CornerDownRight className="w-4 h-4" />
                  <span>{isExpanded ? "Collapse essay" : "Read strategic breakdown →"}</span>
                </div>

                {/* Expanded article details with smooth layout */}
                <AnimatePresence initial={false}>
                  {isExpanded && (
                    <motion.div
                      initial={{ height: 0, opacity: 0, marginTop: 0 }}
                      animate={{ height: "auto", opacity: 1, marginTop: 20 }}
                      exit={{ height: 0, opacity: 0, marginTop: 0 }}
                      transition={{ duration: 0.4, ease: "easeInOut" }}
                      className="overflow-hidden border-t border-gray-100 pt-6 text-left"
                    >
                      <div className="bg-slate-50/50 rounded-2xl p-5 md:p-6 border border-slate-100">
                        <p className="font-sans text-slate-600 text-sm md:text-base leading-relaxed whitespace-pre-line font-light">
                          {tg.content}
                        </p>
                        
                        <div className="mt-8 flex justify-between items-center text-[10px] font-mono text-zinc-400 border-t border-zinc-100 pt-4">
                          <span>WRITTEN BY BRANDGV</span>
                          <span>SIGNAL OVER NOISE SERIES</span>
                        </div>
                      </div>
                    </motion.div>
                  )}
                </AnimatePresence>
              </motion.div>
            );
          })}
        </div>

        {/* View More Button */}
        {visibleCount < sortedThoughts.length && (
          <motion.div
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            className="flex justify-center mt-12"
          >
            <button
              onClick={handleViewMore}
              className="cursor-pointer flex items-center space-x-2 px-8 py-4 bg-white hover:bg-slate-100 text-[#050719] font-sans text-xs font-bold tracking-widest uppercase border border-gray-200 hover:border-gray-300 rounded-full shadow-sm hover:shadow transition-all duration-300 group"
            >
              <span>View More Thoughts</span>
              <ChevronDown className="w-4 h-4 text-slate-400 group-hover:text-[#7B61FF] transition-colors group-hover:translate-y-0.5 transition-transform" />
            </button>
          </motion.div>
        )}
      </div>
    </section>
  );
}
